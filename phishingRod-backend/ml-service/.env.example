# Internal shared secret. Must match Laravel's ML_SERVICE_TOKEN.
ML_SERVICE_TOKEN=dev-internal-token-change-me

# Directory containing the runtime .joblib models (relative to the service
# root or an absolute path).
ML_MODELS_DIR=models

# --- Two-model weighted fusion (optional overrides; defaults shown) ---
# F1-derived weights (normalised at runtime).
ML_WEIGHT_URL=0.475
ML_WEIGHT_HTML=0.525
# Verdict thresholds on the combined phishing probability.
ML_PHISHING_THRESHOLD=0.75
ML_SUSPICIOUS_THRESHOLD=0.45
# Min DOM length (chars) for the HTML model to be trusted; below this -> URL-only.
ML_DOM_MIN_CHARS=200
