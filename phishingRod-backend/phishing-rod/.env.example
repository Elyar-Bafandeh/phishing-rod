# =============================================================================
# Phishing Rod — Laravel API environment
#
# Setup: copy this file to `.env`, then run `php artisan key:generate`.
#
# What you must edit to run a REAL scan (Level 2 in the README):
#   - DB_PASSWORD       your local PostgreSQL password
#   - URLSCAN_API_KEY   a live urlscan.io key (free: https://urlscan.io/user/signup)
#   - ML_SERVICE_TOKEN  must match the same value in ml-service/.env
#
# To run only the AUTOMATED TESTS (Level 1) you need NONE of the above — the test
# suite uses in-memory SQLite and fakes urlscan.io + the ML service. Just copy
# this file, run key:generate, and `php artisan test`.
# =============================================================================

APP_NAME="Phishing Rod"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL — create the `phishing_rod` database first, then `php artisan migrate`.
# (Only needed for real runs; the test suite uses in-memory SQLite instead.)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=phishing_rod
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# urlscan.io — the safe URL-retrieval layer (the app never browses URLs itself).
# URLSCAN_API_KEY is REQUIRED for real scans — get a free key at
# https://urlscan.io/user/signup. Leave blank when only running the test suite.
URLSCAN_BASE_URL=https://urlscan.io
URLSCAN_API_KEY=
URLSCAN_VISIBILITY=unlisted
URLSCAN_TIMEOUT=30

# Internal Python ML service. Model selection + weighted fusion happen inside the
# Python service, so Laravel only needs connection settings (no model name here).
# ML_SERVICE_TOKEN MUST match the same value in ml-service/.env, or /predict
# returns 401 and scans fail at the `predicting` step.
ML_SERVICE_URL=http://127.0.0.1:9000
ML_SERVICE_TOKEN=dev-internal-token-change-me
ML_SERVICE_TIMEOUT=30
